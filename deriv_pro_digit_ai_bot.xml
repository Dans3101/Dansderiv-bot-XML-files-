<xml xmlns="https://developers.google.com/blockly/xml">
  <block type="trade_definition" id="trade">
    <field name="MARKET">Volatility Indices</field>
    <field name="SYMBOL">R_100</field>
    <field name="TRADETYPE">DIGITMATCH</field>
    <field name="DURATION">1</field>
    <field name="DURATIONTYPE">t</field>
    <field name="AMOUNT">0.35</field>
  </block>

  <!-- Digit Frequency Analysis -->
  <block type="tick_analysis" id="digitfreq">
    <field name="ANALYSIS_TYPE">digit_frequency</field>
    <field name="TICKS">100</field>
    <next>
      <block type="set_prediction_digit" id="pred">
        <field name="SOURCE">most_frequent</field>
      </block>
    </next>
  </block>

  <!-- Trade Execution -->
  <block type="trade" id="trade_exec">
    <field name="TRADETYPE">DIGITMATCH</field>
    <field name="PREDICTION_DIGIT">prediction</field>
  </block>

  <!-- On Loss: Switch to Digit Differ -->
  <block type="on_trade_result" id="loss_switch">
    <field name="RESULT">loss</field>
    <next>
      <block type="trade" id="digit_differ">
        <field name="TRADETYPE">DIGITDIFFER</field>
        <field name="PREDICTION_DIGIT">prediction</field>
      </block>
    </next>
  </block>

  <!-- Martingale -->
  <block type="money_management" id="martingale">
    <field name="STRATEGY">martingale</field>
    <field name="MULTIPLIER">2.5</field>
  </block>

  <!-- Risk Management -->
  <block type="risk_management" id="risk">
    <field name="STOP_LOSS">300</field>
    <field name="TAKE_PROFIT">20</field>
  </block>
</xml>
